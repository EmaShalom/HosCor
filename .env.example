# ─────────────────────────────────────────────────────────────────────────────
# HosCor — Environment Variables
# Copy this file to .env and fill in the values.
# The .env file is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=postgres

# JWT signing secret (min 32 characters — use a strong random value in production)
JWT_SECRET=hoscor-super-secret-key-2024-cisss-outaouais-hospital-coord
